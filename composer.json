        "laminas/laminas-form": "^3.19",
        "laminas/laminas-authentication": "^2.11",
        "laminas/laminas-permissions-acl": "^2.12",
        "laminas/laminas-view": "^2.37",
        "laminas/laminas-session": "^2.14",
